# ============================================================
# Psicomichi API - Environment example
# ============================================================
# Copy this file and rename it to `.env` for local development.
#
# IMPORTANT:
# - Do NOT commit your real `.env` file.
# - This file is safe to commit because it contains example values only.
# - Change all sensitive values before using this project in production.
# ============================================================


# ============================================================
# Application
# ============================================================

# Public application name.
APP_NAME=Psicomichi API

# Current environment.
# Common values: development, testing, production
APP_ENV=development

# Enable debug mode only in local development.
# In production this must be false.
DEBUG=true

# API base prefix for version 1 routes.
API_V1_PREFIX=/api/v1


# ============================================================
# Database - PostgreSQL
# ============================================================

# PostgreSQL host.
# Use "localhost" for local development.
# Use the Docker service name when running inside Docker.
POSTGRES_HOST=localhost

# PostgreSQL port.
POSTGRES_PORT=5432

# PostgreSQL database name.
POSTGRES_DB=psicomichi_db

# PostgreSQL username.
POSTGRES_USER=postgres

# PostgreSQL password.
# Change this value in your real `.env`.
POSTGRES_PASSWORD=postgres

# Full database connection URL used by SQLAlchemy and Alembic.
# Format:
# postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/psicomichi_db


# ============================================================
# Security - JWT
# ============================================================

# Secret key used to sign JWT tokens.
# MUST be changed in your real `.env`.
#
# Generate a strong key with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change_me_with_a_long_random_secret

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# Access token expiration time in minutes.
# Recommended local/default value: 15
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration time in days.
# Recommended local/default value: 30
REFRESH_TOKEN_EXPIRE_DAYS=30


# ============================================================
# Rate limiting - Authentication
# ============================================================

# Maximum failed login attempts allowed during the configured window.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Time window in seconds for login rate limiting.
# Example: 60 = 1 minute
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60


# ============================================================
# Frontend / CORS
# ============================================================

# Frontend origin allowed by CORS.
# Vite local development usually runs on http://localhost:5173
FRONTEND_URL=http://localhost:5173

ALLOWED_ORIGINS=["http://localhost:5173"]


# ============================================================
# Refresh token cookie
# ============================================================

# Cookie name used to store the refresh token.
REFRESH_COOKIE_NAME=psicomichi_refresh_token

# Cookie path where the refresh token is valid.
# Keep this limited to auth routes when possible.
REFRESH_COOKIE_PATH=/api/v1/auth

# Prevent JavaScript from reading the refresh cookie.
# Recommended: true
REFRESH_COOKIE_HTTPONLY=true

# SameSite policy for the refresh cookie.
# Common values: lax, strict, none
#
# For local development with same-site frontend/backend:
# REFRESH_COOKIE_SAMESITE=lax
#
# For cross-site production deployments, you may need:
# REFRESH_COOKIE_SAMESITE=none
# and REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax

# Send cookie only over HTTPS.
# Local development: false
# Production: true
REFRESH_COOKIE_SECURE=false

# Refresh cookie max age in seconds.
# 2592000 = 30 days
REFRESH_COOKIE_MAX_AGE_SECONDS=2592000